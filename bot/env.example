# ─────────────────────────────────────────────────────────────
# Decibel Bot — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy file này thành .env rồi điền vào

# Aptos private key (export từ Petra: Settings → Private key)
PRIVATE_KEY=0x

# Network: mainnet hoặc testnet
NETWORK=mainnet

# Market muốn trade
MARKET=APT-USD

# Builder address — địa chỉ ví Aptos của mày để nhận fee
BUILDER_ADDRESS=0x949b1c05428025a83ea49ba76d0ff0fafc015506b70a027af4a9c8f0c17ff517

# Builder fee (basis points) — 2 = 0.02%
BUILDER_FEE_BPS=2

# Geomi API key (đăng ký tại geomi.dev)
DECIBEL_API_KEY=aptoslabs_

# Sub-account address — để trống lúc đầu, chạy setup xong thì điền vào
SUBACCOUNT_ADDR=
